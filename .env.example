# SlangToon - AI Slang Comic Generator

# Qwen Image Generation (DashScope)
qwen_image_apikey=your-dashscope-api-key
qwen_image_base_url=https://dashscope.aliyuncs.com/api/v1
qwen_image_model=qwen-image-2.0

# Image generation provider: "dashscope" | "openrouter" | "replicate"
IMAGE_GEN_PROVIDER=dashscope

# OpenRouter image generation (when IMAGE_GEN_PROVIDER=openrouter)
OPENROUTER_IMAGE_APIKEY=your-openrouter-api-key
OPENROUTER_IMAGE_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Replicate image generation (when IMAGE_GEN_PROVIDER=replicate)
REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_IMAGE_MODEL=openai/gpt-image-2
# Model-specific extra params as JSON (optional):
#   gpt-image-2: '{"quality":"auto","moderation":"auto","background":"auto","output_format":"png","number_of_images":1}'
#   imagen-4:    '{"output_format":"png","number_of_images":1}'
#   All Replicate model params can be set here, only prompt + aspect_ratio are auto-filled
REPLICATE_IMAGE_EXTRA_PARAMS=

# Text LLM (GLM via BigModel, OpenAI-compatible)
OPENAI_API_KEY=your-bigmodel-api-key
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4.6v
vision_llm_timeout=120

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# -- LangSmith cloud tracing (optional) --
# Standard LangSmith SDK environment variables
# When set, LangGraph + @traceable automatically report traces to LangSmith cloud
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=slangtoon
