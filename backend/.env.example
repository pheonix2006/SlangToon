# ===== Qwen Image 2.0 配置 =====
qwen_image_apikey=your-qwen-image-api-key
qwen_image_base_url=https://dashscope.aliyuncs.com/api/v1
qwen_image_model=qwen-image-2.0

# ===== Image generation provider =====
IMAGE_GEN_PROVIDER=dashscope

# ===== OpenRouter image generation =====
OPENROUTER_IMAGE_APIKEY=your-openrouter-api-key
OPENROUTER_IMAGE_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# ===== Vision LLM 配置 (OpenAI-compatible) =====
OPENAI_API_KEY=your-vision-llm-api-key
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4.6v
